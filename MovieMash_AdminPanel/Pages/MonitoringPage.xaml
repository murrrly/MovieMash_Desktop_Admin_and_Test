<Page x:Class="MovieApp_Adminpanel.Pages.MonitoringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мониторинг">

	<StackPanel Margin="20">

		<DataGrid x:Name="LogsGrid"
                  Height="500"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  IsReadOnly="True"
                  MouseDoubleClick="LogsGrid_MouseDoubleClick">

			<DataGrid.Columns>

				<DataGridTextColumn Header="Пользователь"
                                    Binding="{Binding Username}"
                                    Width="200"/>

				<DataGridTextColumn Header="Действие"
                                    Binding="{Binding Activity}"
                                    Width="300"/>

				<DataGridTextColumn Header="Дата"
                                    Binding="{Binding Date}"
                                    Width="200"/>

			</DataGrid.Columns>

		</DataGrid>

		<Button Content="Обновить"
                Width="120"
                Margin="0 20 0 0"
                Click="Refresh_Click"/>

	</StackPanel>
</Page>