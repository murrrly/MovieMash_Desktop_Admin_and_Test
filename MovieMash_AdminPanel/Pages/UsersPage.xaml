<Page x:Class="MovieApp_Adminpanel.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пользователи" Background="Transparent">

	<StackPanel Margin="20">

		<StackPanel Orientation="Horizontal" Margin="0,0,0,15">
			<!-- Поиск теперь с подсказкой (Tag) и в темном стиле из App.xaml -->
			<TextBox x:Name="SearchBox" Width="300" Tag="Поиск по имени или email..."
                     TextChanged="SearchBox_TextChanged" Padding="8,0,0,0"/>

			<Button Content="Экспорт в JSON" Margin="15,0" Width="140" Click="ExportCsv_Click" 
                    Background="{StaticResource MediumBlack}"/>
		</StackPanel>

		<DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="550"
                  BorderThickness="0" GridLinesVisibility="None">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Имя пользователя" Binding="{Binding Username}" Width="1.5*"/>
				<DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>

				<!-- Статус текстом -->
				<DataGridTemplateColumn Header="Статус" Width="100">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding IsActive}" 
                                       Foreground="{Binding StatusColor}" 
                                       FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<DataGridTextColumn Header="Регистрация" Binding="{Binding CreatedAt}" Width="120"/>

				<!-- КНОПКА ДЕЙСТВИЯ -->
				<DataGridTemplateColumn Header="Действие" Width="150">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<Button Content="{Binding ActionText}" 
                                    Background="{Binding ActionColor}"
                                    Height="28" FontSize="11" Margin="2"
                                    Click="ToggleStatus_Click"
                                    Tag="{Binding Email}"/>
							<!-- Привязываем Email к Tag, чтобы найти юзера в БД -->
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>
	</StackPanel>
</Page>