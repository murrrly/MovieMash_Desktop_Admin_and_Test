<Page x:Class="MovieApp_Adminpanel.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="Transparent">

	<StackPanel Margin="20">
		<!-- КАРТОЧКИ СТАТИСТИКИ -->
		<WrapPanel HorizontalAlignment="Left" Margin="0,0,0,20">
			<!-- Новые сегодня -->
			<Border Background="{StaticResource White}" Width="210" Height="100" Margin="8" Padding="15" CornerRadius="12" Effect="{StaticResource DropShadowEffect}">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Новые (сегодня)" Foreground="{StaticResource Gray}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBlock x:Name="NewUsersCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkBlack}"/>
				</StackPanel>
			</Border>

			<!-- Всего пользователей -->
			<Border Background="{StaticResource White}" Width="210" Height="100" Margin="8" Padding="15" CornerRadius="12" Effect="{StaticResource DropShadowEffect}">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Всего в базе" Foreground="{StaticResource Gray}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBlock x:Name="TotalUsersCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkBlack}"/>
				</StackPanel>
			</Border>

			<!-- Очередь модерации -->
			<Border Background="{StaticResource White}" Width="210" Height="100" Margin="8" Padding="15" CornerRadius="12" Effect="{StaticResource DropShadowEffect}">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Ожидают проверки" Foreground="{StaticResource Gray}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBlock x:Name="PendingReviewsCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
				</StackPanel>
			</Border>

			<!-- Статус API -->
			<Border Background="{StaticResource White}" Width="210" Height="100" Margin="8" Padding="15" CornerRadius="12" Effect="{StaticResource DropShadowEffect}">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Статус TMDB" Foreground="{StaticResource Gray}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<StackPanel Orientation="Horizontal">
						<Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource Gray}" Margin="0,0,8,0"/>
						<TextBlock x:Name="TmdbStatus" Text="ПРОВЕРКА..." FontSize="22" FontWeight="Bold" Foreground="{StaticResource DarkBlack}"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</WrapPanel>

		<!-- СПИСОК СОБЫТИЙ -->
		<GroupBox Header="Последние события" Margin="0,0,0,15">
			<ListBox x:Name="RecentEventsList" Height="220"/>
		</GroupBox>

		<!-- КНОПКИ ДЕЙСТВИЙ -->
		<WrapPanel>
			<Button Content="Перейти к модерации" Width="180" Margin="5" Click="GoToModeration_Click"/>
			<Button Content="Посмотреть логи" Width="180" Margin="5" Click="GoToMonitoring_Click"/>

			<Button Content="Выйти из аккаунта" 
                    Width="180" Margin="5" 
                    Background="{StaticResource PrimaryRed}" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Click="ExitButton_Click"/>
		</WrapPanel>
	</StackPanel>
</Page>