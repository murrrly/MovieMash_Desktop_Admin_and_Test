<Window x:Class="MovieApp_Adminpanel.Pages.LogDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали лога"
        Width="400"
        Height="250"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

	<StackPanel Margin="20">

		<TextBlock x:Name="UserText"
                   Foreground="White"
                   FontSize="16"
                   Margin="0,0,0,10"/>

		<TextBlock x:Name="ActivityText"
                   Foreground="White"
                   Margin="0,0,0,10"/>

		<TextBlock x:Name="DateText"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

		<TextBlock x:Name="MovieText"
                   Foreground="Orange"
                   FontSize="14"/>

	</StackPanel>

</Window>