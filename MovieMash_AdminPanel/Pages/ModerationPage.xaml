<Page x:Class="MovieApp_Adminpanel.Pages.ModerationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Модерация"
      Background="Transparent">

	<!-- ROOT WRAPPER -->
	<Grid>

		<!-- ================= MAIN LAYOUT ================= -->
		<Grid Margin="0">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- ================= MAIN UI ================= -->
			<TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">

				<!-- ================= SUPPORT ================= -->
				<TabItem Header="Сообщения от пользователей">

					<Grid Margin="0">

						<DataGrid x:Name="SupportMessagesGrid"
                                  AutoGenerateColumns="False"
                                  Background="{StaticResource DarkBlack}"
                                  IsReadOnly="True"
                                  MouseDoubleClick="SupportMessagesGrid_MouseDoubleClick">

							<DataGrid.Columns>
								<DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="180"/>
								<DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
								<DataGridTextColumn Header="Тема" Binding="{Binding Subject}" Width="*"/>
								<DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="120"/>
								<DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="130"/>
							</DataGrid.Columns>

						</DataGrid>

					</Grid>

				</TabItem>

				<!-- ================= MODERATION ================= -->
				<TabItem Header="Очередь (Pending)">

					<DataGrid x:Name="ModerationGrid"
                              AutoGenerateColumns="False"
							  Margin="0"
                              Background="{StaticResource DarkBlack}"
                              IsReadOnly="True">
						<DataGrid.CellStyle>
							<Style TargetType="DataGridCell">
								<Setter Property="VerticalAlignment" Value="Top"/>
								<Setter Property="VerticalContentAlignment" Value="Top"/>
							</Style>
						</DataGrid.CellStyle>

						<DataGrid.Columns>

							<DataGridTextColumn Header="Автор"
                     Binding="{Binding Username}"
                     Width="120"/>

							<DataGridTextColumn Header="ID Фильма"
                     Binding="{Binding MovieTitle}"
                     Width="150"/>

							<DataGridTemplateColumn Header="Текст" Width="*">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock x:Name="ReviewTextBlock"
					   TextWrapping="Wrap"
					   Loaded="ReviewText_Loaded"
					   VerticalAlignment="Top"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTextColumn Header="Дата"
                     Binding="{Binding CreatedAt}"
                     Width="100"/>

							<DataGridTemplateColumn Header="Действия" Width="Auto">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal"
						VerticalAlignment="Top">

											<Button Content="Одобрить"
						Background="Green"
						Foreground="White"
						Width="80"
						Margin="0,0,5,0"
						Click="Approve_Click"/>

											<Button Content="Отклонить"
						Background="{StaticResource PrimaryRed}"
						Foreground="White"
						Width="80"
						Click="Reject_Click"/>

										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

						</DataGrid.Columns>

					</DataGrid>

				</TabItem>

				<!-- ================= ALL REVIEWS ================= -->
				<TabItem Header="История всех отзывов"
                         Selector.Selected="AllReviewsTab_Selected">

					<StackPanel Margin="0">

						<StackPanel Orientation="Horizontal" Margin="0,0,0,10">

							<TextBox x:Name="SearchBoxAll"
                                     Width="250"
                                     TextChanged="SearchBoxAll_TextChanged"
                                     Padding="8,0,0,0"/>

							<TextBlock Text="🔍"
                                       VerticalAlignment="Center"
                                       Margin="-30,0"
                                       Foreground="{StaticResource Gray}"/>

						</StackPanel>

						<DataGrid x:Name="AllReviewsGrid"
                                  AutoGenerateColumns="False"
                                  Height="460"
                                  Background="{StaticResource DarkBlack}"
                                  IsReadOnly="True">

							<DataGrid.Columns>

								<DataGridTextColumn Header="Автор"
                                                    Binding="{Binding Username}"
                                                    Width="120"/>

								<DataGridTemplateColumn Header="Текст" Width="*">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding ReviewText}"
                                                       TextWrapping="Wrap"
                                                       Foreground="White"
                                                       Margin="5"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>

								<DataGridTemplateColumn Header="Статус" Width="100">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding StatusText}"
                                                       Foreground="White"
                                                       FontWeight="Bold"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>

								<DataGridTextColumn Header="Дата"
                                                    Binding="{Binding CreatedAt}"
                                                    Width="100"/>

							</DataGrid.Columns>

						</DataGrid>

					</StackPanel>

				</TabItem>

			</TabControl>

		</Grid>

		<!-- ================= TOAST OVERLAY (НЕ ЛОМАЕТ LAYOUT) ================= -->
		<Grid IsHitTestVisible="False">

			<Border x:Name="InfoToast"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,15,0,0"
                    Background="#CC2D2D2D"
                    CornerRadius="10"
                    Padding="12"
                    Opacity="0"
                    Visibility="Collapsed"
                    Panel.ZIndex="999"
                    RenderTransformOrigin="0.5,0.5">

				<Border.RenderTransform>
					<TranslateTransform Y="-20"/>
				</Border.RenderTransform>

				<TextBlock x:Name="InfoToastText"
                           Foreground="White"
                           FontSize="14"/>
			</Border>

		</Grid>

	</Grid>
</Page>