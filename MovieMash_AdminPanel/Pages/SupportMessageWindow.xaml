<Window x:Class="MovieApp_Adminpanel.Windows.SupportMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сообщение пользователя"
        Height="750"
        Width="900"
        Background="#111111"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="20">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="300"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="100"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ИМЯ -->
		<TextBlock x:Name="NameText"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"/>

		<!-- ВРЕМЯ -->
		<TextBlock x:Name="DateText"
                   Grid.Row="1"
                   Margin="0,5,0,0"
                   FontSize="14"
                   Foreground="#AAAAAA"/>

		<!-- ТЕМА -->
		<TextBlock x:Name="SubjectText"
                   Grid.Row="2"
                   Margin="0,10,0,20"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#DDDDDD"/>

		<!-- СООБЩЕНИЕ -->
		<Border Grid.Row="3"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">

			<ScrollViewer VerticalScrollBarVisibility="Auto">

				<TextBlock x:Name="MessageText"
                           Foreground="White"
                           FontSize="15"
                           TextWrapping="Wrap"/>

			</ScrollViewer>

		</Border>

		<!-- ЗАГОЛОВОК ОТВЕТА -->
		<TextBlock Grid.Row="4"
                   Text="Ответ:"
                   Margin="0,20,0,10"
                   Foreground="White"
                   FontWeight="Bold"
                   FontSize="18"/>

		<!-- ПОЛЕ ОТВЕТА -->
		<TextBox x:Name="ReplyBox"
                 Grid.Row="5"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Hidden"
                 FontSize="15"
                 Padding="5"
                 Height="100"/>

		<!-- КНОПКА -->
		<Button Grid.Row="6"
                Content="Отправить ответ"
                Width="200"
                Height="45"
                HorizontalAlignment="Right"
                Margin="0,20,0,0"
                FontSize="15"
                FontWeight="Bold"
                Click="SendReply_Click"/>
	</Grid>
</Window>