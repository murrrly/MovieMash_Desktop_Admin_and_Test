<Window x:Class="MovieApp_Adminpanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Library Admin" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White"
        Icon="/Assets/app.ico">

	<Window.Resources>
		<!-- Твой стиль для MenuItem -->
		<Style TargetType="MenuItem" x:Key="MainMenuItemStyle">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="20,10"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="MenuItem">
						<Border x:Name="Border" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
							<TextBlock Text="{TemplateBinding Header}" Foreground="White"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
							</Trigger>
							<Trigger Property="Tag" Value="Active">
								<Setter TargetName="Border" Property="Background" Value="#007ACC"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<DockPanel>
		<!-- Верхнее меню с именами (x:Name), которые ищет C# -->
		<Menu DockPanel.Dock="Top" Background="#2D2D30" Height="40">
			<MenuItem x:Name="MenuDashboard" Header="Главная" Click="Dashboard_Click" Style="{StaticResource MainMenuItemStyle}"/>
			<MenuItem x:Name="MenuUsers" Header="Пользователи" Click="Users_Click" Style="{StaticResource MainMenuItemStyle}"/>
			<MenuItem x:Name="MenuModeration" Header="Модерация" Click="Moderation_Click" Style="{StaticResource MainMenuItemStyle}"/>
			<MenuItem x:Name="MenuMonitoring" Header="Логи" Click="Monitoring_Click" Style="{StaticResource MainMenuItemStyle}"/>
			<MenuItem x:Name="MenuProfile" Header="Профиль" Click="AdminProfile_Click" Style="{StaticResource MainMenuItemStyle}"/>
		</Menu>

		<TextBlock x:Name="PageTitle" FontSize="26" FontWeight="Bold" Margin="20,10" DockPanel.Dock="Top" Text="Главная"/>

		<Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="10"/>
	</DockPanel>
</Window>